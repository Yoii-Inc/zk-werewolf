# SOPS encrypted secrets template
# Copy this file to secrets.enc.yaml and edit with your actual values
# Then encrypt: sops -e -i secrets.enc.yaml

# Backend API secrets
backend:
  supabase_url: "https://your-project.supabase.co"
  supabase_key: "your-supabase-anon-key"
  jwt_secret: "your-jwt-secret-key"
  blockchain_enabled: true
  ethereum_rpc_url: "https://eth-sepolia.g.alchemy.com/v2/your-alchemy-api-key"
  ethereum_chain_id: 11155111
  deployer_private_key: "0xyour-private-key"
  werewolf_game_contract: "0xYourWerewolfGameContractAddress"
  werewolf_verifier_contract: "0xYourWerewolfVerifierContractAddress"
  werewolf_rewards_contract: "0xYourWerewolfRewardsContractAddress"

# MPC Node secrets (if needed)
mpc_nodes:
  node_0:
    public_key: "node-0-public-key"
    private_key: "node-0-private-key"
  node_1:
    public_key: "node-1-public-key"
    private_key: "node-1-private-key"
  node_2:
    public_key: "node-2-public-key"
    private_key: "node-2-private-key"

# Database credentials (if using RDS instead of Supabase)
database:
  host: "your-rds-endpoint"
  port: "5432"
  username: "postgres"
  password: "your-db-password"
  database: "zk_werewolf"
