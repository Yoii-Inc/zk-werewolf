        for (uint i = 0; i < input.length; i++) {
            require(input[i] < snark_scalar_field);
            vk_x = RoleAssignmentN7W2Groth16VerifierPairing.addition(vk_x, RoleAssignmentN7W2Groth16VerifierPairing.scalar_mul(vk.gamma_abc[i + 1], input[i]));
        }
        vk_x = RoleAssignmentN7W2Groth16VerifierPairing.addition(vk_x, vk.gamma_abc[0]);
        if(!RoleAssignmentN7W2Groth16VerifierPairing.pairingProd4(
             proof.a, proof.b,
             RoleAssignmentN7W2Groth16VerifierPairing.negate(vk_x), vk.gamma,
             RoleAssignmentN7W2Groth16VerifierPairing.negate(proof.c), vk.delta,
             RoleAssignmentN7W2Groth16VerifierPairing.negate(vk.alpha), vk.beta)) return 1;
        return 0;
    }
    function verifyTx(
            Proof memory proof, uint[169] memory input
        ) public view returns (bool r) {
        uint[] memory inputValues = new uint[](169);
        
        for(uint i = 0; i < input.length; i++){
            inputValues[i] = input[i];
        }
        if (verify(inputValues, proof) == 0) {
            return true;
        } else {
            return false;
        }
    }
}
