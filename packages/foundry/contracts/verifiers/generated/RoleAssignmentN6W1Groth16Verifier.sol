    function verify(uint[] memory input, Proof memory proof) internal view returns (uint) {
        uint256 snark_scalar_field = uint256(0x30644E72E131A029B85045B68181585D2833E84879B9709143E1F593F0000001);
        VerifyingKey memory vk = verifyingKey();
        require(input.length + 1 == vk.gamma_abc.length);
        // Compute the linear combination vk_x
        RoleAssignmentN6W1Groth16VerifierPairing.G1Point memory vk_x = RoleAssignmentN6W1Groth16VerifierPairing.G1Point(0, 0);
        for (uint i = 0; i < input.length; i++) {
            require(input[i] < snark_scalar_field);
            vk_x = RoleAssignmentN6W1Groth16VerifierPairing.addition(vk_x, RoleAssignmentN6W1Groth16VerifierPairing.scalar_mul(vk.gamma_abc[i + 1], input[i]));
        }
        vk_x = RoleAssignmentN6W1Groth16VerifierPairing.addition(vk_x, vk.gamma_abc[0]);
        if(!RoleAssignmentN6W1Groth16VerifierPairing.pairingProd4(
             proof.a, proof.b,
             RoleAssignmentN6W1Groth16VerifierPairing.negate(vk_x), vk.gamma,
             RoleAssignmentN6W1Groth16VerifierPairing.negate(proof.c), vk.delta,
             RoleAssignmentN6W1Groth16VerifierPairing.negate(vk.alpha), vk.beta)) return 1;
        return 0;
    }
    function verifyTx(
            Proof memory proof, uint[144] memory input
        ) public view returns (bool r) {
        uint[] memory inputValues = new uint[](144);
        
        for(uint i = 0; i < input.length; i++){
            inputValues[i] = input[i];
        }
        if (verify(inputValues, proof) == 0) {
            return true;
        } else {
            return false;
        }
    }
